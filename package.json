{
  "name": "catspin-arena",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -k -n server,web \"pnpm --filter @catspin/server dev\" \"pnpm --filter @catspin/web dev\"",
    "dev:server": "pnpm --filter @catspin/server dev",
    "dev:web": "pnpm --filter @catspin/web dev",
    "dev:slot": "pnpm --filter @catspin/slot dev",
    "dev:all": "concurrently -k -n server,web,slot \"pnpm --filter @catspin/server dev\" \"pnpm --filter @catspin/web dev\" \"pnpm --filter @catspin/slot dev\"",
    "preview:web": "pnpm --filter @catspin/web preview",
    "preview:slot": "pnpm --filter @catspin/slot preview",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "sim:core": "pnpm --filter @catspin/core sim",
    "sim:core:fast": "pnpm --filter @catspin/core sim:fast",
    "sim:core:rtp": "pnpm --filter @catspin/core sim:rtp",
    "structure": "node tools/structure.mjs",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "clean": "pnpm -r exec rimraf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "fast-glob": "^3.3.3"
  }
}
