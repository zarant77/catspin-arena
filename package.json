{
  "name": "catspin-arena",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @catspin/server --filter @catspin/web dev",
    "dev:server": "pnpm --filter @catspin/server dev",
    "dev:web": "pnpm --filter @catspin/web dev",
    "preview:web": "pnpm --filter @catspin/web preview",
    "typecheck": "pnpm -r typecheck",
    "structure": "node tools/structure.mjs",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "clean": "pnpm -r exec rimraf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "fast-glob": "^3.3.3"
  }
}
