{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../..",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "ws"],
    "strict": true
  },
  "include": ["src/**/*.ts", "../../packages/*/src/**/*.ts"],
  "exclude": ["**/*.test.ts", "../../packages/*/src/**/*.test.ts"]
}
